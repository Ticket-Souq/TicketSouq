# Anyone in the org can branch/edit/PR anywhere.
# This file only controls who must APPROVE a PR before it can merge.
# Format: path   @Ticket-Souq/team-slug

# ---- Infra (shared by everyone, no single owner) ----
/config-server/                     @Ticket-Souq/infra-team

# ---- Core services ----
/eureka-service/                     @Ticket-Souq/eureka-team
/auth-service/                       @Ticket-Souq/auth-team
/ticket-service/                     @Ticket-Souq/ticket-team
/venue-service/                      @Ticket-Souq/venue-team
/analytics-service/                  @Ticket-Souq/analytics-audit-team
/audit-service/                      @Ticket-Souq/analytics-audit-team
/notification-service/               @Ticket-Souq/notification-team
/availability-locking-service/       @Ticket-Souq/availability-locking-team
/event-service/                      @Ticket-Souq/event-team
/payment-service/                    @Ticket-Souq/payment-team
/reservation-service/                @Ticket-Souq/reservation-team

